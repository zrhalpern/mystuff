# Example of how to migrate a GPO using PowerShell and Intune Win32 app.

# Path to reg key we want migrated
$Key1          = "Registry\Path\To\Location"
$Value1        = "Reg_Key"
$Data1         = 1

# The root directory
$regDirectory  = "Registry::HKCU"
$strType       = "DWord"

# The detection method
$Key2          =  "Registry\Path\To\Location"
$Value2        = "MyStuff"
$Data2         = 1

Try {
    If (!(Get-Item ($RegDirectory + "\" + $Key1) -ErrorAction SilentlyContinue)) { New-Item -Path ($regDirectory + "\" + $Key1) -ErrorAction SilentlyContinue -Force | out-null }
    If (!(Get-Item ($RegDirectory + "\" + $Key2) -ErrorAction SilentlyContinue)) { New-Item -Path ($regDirectory + "\" + $Key2) -ErrorAction SilentlyContinue -Force | out-null }
    
    Set-ItemProperty -Path ($regDirectory + "\" + $Key1) -Name $Value -Value $Data1 -Type $strType
    Set-ItemProperty -Path ($regDirectory + "\" + $Key2) -Name $Value -Value $Data2 -Type $strType
}
Catch {
      Write-Host $_.Exception
}
